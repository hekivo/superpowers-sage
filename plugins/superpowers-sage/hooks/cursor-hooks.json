{
  "hooks": {
    "userPromptSubmit": [
      {
        "command": "bash \"./hooks/user-prompt-activate.sh\""
      }
    ],
    "sessionStart": [
      {
        "command": "bash \"./hooks/session-start.sh\""
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash \"./hooks/post-edit.sh\""
      }
    ],
    "preCompact": [
      {
        "command": "bash \"./hooks/post-compact.sh\""
      }
    ],
    "beforeShellExecution": [
      {
        "command": "bash \"./hooks/pre-commit.sh\"",
        "matcher": "git commit"
      }
    ],
    "beforeFileEdit": [
      {
        "command": "bash \"./hooks/pre-write-protected.sh\""
      }
    ],
    "subagentStop": [
      {
        "command": "bash \"./hooks/post-subagent.sh\""
      }
    ],
    "stop": [
      {
        "command": "bash \"./hooks/post-stop.sh\""
      }
    ]
  }
}
